{
  "name": "sculptor-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "app",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @sculptor/config && npm run build --workspace @sculptor/paws && npm run build --workspace @sculptor/router && npm run build --workspace @sculptor/core && npm run build --workspace @sculptor/cli && npm -w app run build",
    "start": "npm -w app run start",
    "dev": "npm -w app run dev",
    "cli": "npm -w packages/cli run cli",
    "pretest": "npm run build",
    "lint": "eslint . --ext .ts",
    "test": "vitest run"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.20.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
